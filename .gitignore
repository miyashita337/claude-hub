# Environment
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Logs
logs/
*.log

# Runtime
pids/

# OS
.DS_Store

# Screenshots (local only)
screenshots/

# Generated plist (contains local paths; regenerate via scripts/install-hijoguchi.sh)
com.claude-hub.hijoguchi.plist

# Supervisor relay URL marker files
.supervisor-relay-url

# Claude Code local state.
# Track the project-level permissions policy so the hijoguchi Bot loads a
# consistent allow/deny set across clones (Issue #53). Local overrides go
# in .claude/settings.local.json which stays ignored via the glob below.
.claude/*
!.claude/settings.json

# Superpowers skill local state (personal / per-clone brainstorm / plans)
.superpowers/
